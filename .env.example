# =============================================================================
#  Voice Agentic AI – Environment Configuration
#  Copy this file:  cp .env.example .env
#  Then fill in your GROQ_API_KEY (free at https://console.groq.com)
# =============================================================================

# ─── LLM PROVIDER ────────────────────────────────────────────────────────────
# OPTION A: Groq – FREE, fastest setup
#   Get key at: https://console.groq.com → API Keys → Create API Key
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_paste_your_groq_key_here
GROQ_MODEL=llama3-8b-8192
# Other free Groq models: llama3-70b-8192, mixtral-8x7b-32768, gemma2-9b-it

# OPTION B: OpenAI (paid) – uncomment and comment out Groq lines above
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_MODEL=gpt-4o-mini

# OPTION C: No key – rule-based mode, works offline (just set below)
# LLM_PROVIDER=mock

LLM_TEMPERATURE=0.2

# ─── VOICE: Speech-to-Text ────────────────────────────────────────────────────
# Whisper runs LOCALLY – no API key, no internet needed for STT.
# Model sizes: tiny(39MB) | base(74MB) | small(244MB) | medium(769MB)
# Start with "tiny" – download happens automatically on first run.
WHISPER_MODEL=tiny

# ─── VOICE: Text-to-Speech ────────────────────────────────────────────────────
# gtts = Google Translate TTS – FREE, needs internet, outputs .mp3
TTS_PROVIDER=gtts
# For ElevenLabs (paid, better quality):
# TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=your-key
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── MEMORY ───────────────────────────────────────────────────────────────────
# simple = zero deps, in-memory keyword search (default)
# faiss  = install: pip install faiss-cpu
# chroma = install: pip install chromadb
VECTOR_STORE=simple

# ─── EMAIL ────────────────────────────────────────────────────────────────────
# mock = built-in demo emails (default, works without any config)
EMAIL_PROVIDER=mock
# Real Gmail (optional):
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=your-gmail-app-password

# ─── CALENDAR ─────────────────────────────────────────────────────────────────
# mock = built-in demo calendar (default)
CALENDAR_PROVIDER=mock

# ─── APP ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
AUDIO_OUTPUT_DIR=./data/audio
UPLOAD_DIR=./data/uploads
MAX_AUDIO_SIZE_MB=25
